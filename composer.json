{
    "name": "typidesign/laravel-artisan-translations",
    "description": "An artisan command to update json translation files.",
    "keywords": [
        "typidesign",
        "laravel-artisan-translations"
    ],
    "homepage": "https://github.com/typidesign/laravel-artisan-translations",
    "license": "MIT",
    "authors": [
        {
            "name": "Samuel De Backer",
            "email": "sdebacker@gmail.com",
            "homepage": "https://typi.be",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/console": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/filesystem": "^10.0|^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0|^11.0",
        "pestphp/pest": "^1.20|^2.0|^3.0|^4.0",
        "driftingly/rector-laravel": "^1.0|^2.1",
        "larastan/larastan": "^2.11.2|^3.9",
        "laravel/pint": "^1.20"
    },
    "autoload": {
        "psr-4": {
            "Typidesign\\Translations\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Typidesign\\Translations\\Tests\\": "tests"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Typidesign\\Translations\\ArtisanTranslationsServiceProvider"
            ]
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
